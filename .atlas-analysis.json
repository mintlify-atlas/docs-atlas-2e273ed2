  "keyFeatures": [
    "Data-driven worldgen modifiers for structures, terrain, and features",
    "Bandlands terrain generation system with customizable bands",
    "Enhanced structure template pool system with aliases and delegation",
    "Custom density functions and surface rules for terrain shaping",
    "Block predicates, placement modifiers, and placement conditions",
    "Structure processors with advanced conditional logic",
    "Custom features including dungeons, ore generation, and decorations",
    "Cross-loader compatibility (Fabric and NeoForge)"
  ],
  "publicApiSurface": [
    "Modifier - Base interface for worldgen modifiers",
    "AddTemplatePoolElementsModifier - Add elements to structure pools",
    "AddSurfaceRuleModifier - Add custom surface rules",
    "SetPoolAliasesModifier - Configure pool aliases",
    "WrapDensityFunctionModifier - Modify density functions",
    "Band - Bandlands terrain band system",
    "BandlandsRule - Surface rule for bandlands",
    "DelegatingPoolElement - Pool element delegation",
    "ConditionProcessor - Conditional structure processing",
    "PlacementCondition - Feature placement conditions",
    "BlockStatePredicate - Block state testing",
    "WeightedProvider - Weighted block state selection",
    "CompositeFeature - Combine multiple features",
    "DungeonFeature - Custom dungeon generation",
    "LargeDripstoneFeature - Enhanced dripstone caves"
  ]
